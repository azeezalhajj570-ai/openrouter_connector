<odoo>
    <record id="view_openrouter_company_list" model="ir.ui.view">
        <field name="name">ai.openrouter.company.list</field>
        <field name="model">ai.openrouter.company</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="external_code" optional="hide"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_openrouter_company_form" model="ir.ui.view">
        <field name="name">ai.openrouter.company.form</field>
        <field name="model">ai.openrouter.company</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="external_code"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_openrouter_company_search" model="ir.ui.view">
        <field name="name">ai.openrouter.company.search</field>
        <field name="model">ai.openrouter.company</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="external_code"/>
                <separator/>
                <filter name="filter_active" string="Active" domain="[('active','=',True)]"/>
                <filter name="filter_inactive" string="Archived" domain="[('active','=',False)]"/>
            </search>
        </field>
    </record>

    <record id="action_openrouter_company" model="ir.actions.act_window">
        <field name="name">OpenRouter Provider</field>
        <field name="res_model">ai.openrouter.company</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_openrouter_company_search"/>
    </record>
</odoo>
