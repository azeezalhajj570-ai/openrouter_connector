<odoo>
    <record id="view_openrouter_request_log_list" model="ir.ui.view">
        <field name="name">ai.openrouter.request.log.list</field>
        <field name="model">ai.openrouter.request.log</field>
        <field name="arch" type="xml">
            <list create="false" edit="false" delete="false">
                <field name="request_ts"/>
                <field name="provider_id"/>
                <field name="model_id"/>
                <field name="generation_id" optional="hide"/>
                <field name="prompt_tokens"/>
                <field name="completion_tokens"/>
                <field name="total_tokens"/>
                <field name="reasoning_tokens" optional="hide"/>
                <field name="cached_tokens" optional="hide"/>
                <field name="cache_write_tokens" optional="hide"/>
                <field name="audio_tokens" optional="hide"/>
                <field name="total_cost"/>
                <field name="upstream_inference_cost" optional="hide"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_openrouter_request_log_form" model="ir.ui.view">
        <field name="name">ai.openrouter.request.log.form</field>
        <field name="model">ai.openrouter.request.log</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="request_ts"/>
                        <field name="provider_id"/>
                        <field name="model_id"/>
                        <field name="generation_id"/>
                        <field name="state"/>
                        <field name="response_attachment_id" invisible="not response_attachment_id"/>
                        <field name="request_attachment_id" invisible="not request_attachment_id"/>
                    </group>
                    <group>
                        <field name="prompt_tokens"/>
                        <field name="completion_tokens"/>
                        <field name="total_tokens"/>
                        <field name="reasoning_tokens"/>
                        <field name="cached_tokens"/>
                        <field name="cache_write_tokens"/>
                        <field name="audio_tokens"/>
                        <field name="total_cost"/>
                        <field name="upstream_inference_cost"/>
                    </group>
                    <group>
                        <field name="response_text"/>
                    </group>
                    <group>
                        <field name="request_payload_preview" widget="text" invisible="not request_payload_preview"/>
                        <field name="response_payload_preview" widget="text" invisible="not response_payload_preview"/>
                        
                         <!-- Full Payloads (System only) -->
                        <field name="request_payload" widget="text" groups="base.group_system" invisible="not request_payload"/>
                        <field name="response_payload" widget="text" groups="base.group_system" invisible="not response_payload"/>
                        
                        <field name="usage_payload" widget="json"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_openrouter_request_log_search" model="ir.ui.view">
        <field name="name">ai.openrouter.request.log.search</field>
        <field name="model">ai.openrouter.request.log</field>
        <field name="arch" type="xml">
            <search>
                <field name="model_id"/>
                <field name="provider_id"/>
                <field name="generation_id"/>
                <separator/>
                <filter name="filter_success" string="Success" domain="[('state','=','success')]"/>
                <filter name="filter_error" string="Error" domain="[('state','=','error')]"/>
                <filter name="group_state" string="State" context="{'group_by':'state'}"/>
                <filter name="group_date" string="Date" context="{'group_by':'request_ts'}"/>
            </search>
        </field>
    </record>

    <record id="action_openrouter_request_log" model="ir.actions.act_window">
        <field name="name">OpenRouter Usage Logs</field>
        <field name="res_model">ai.openrouter.request.log</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_openrouter_request_log_search"/>
    </record>
</odoo>
