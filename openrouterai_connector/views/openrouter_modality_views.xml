<odoo>
    <record id="view_openrouter_modality_list" model="ir.ui.view">
        <field name="name">ai.openrouter.modality.list</field>
        <field name="model">ai.openrouter.modality</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
                <field name="create_date" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_openrouter_modality_search" model="ir.ui.view">
        <field name="name">ai.openrouter.modality.search</field>
        <field name="model">ai.openrouter.modality</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
            </search>
        </field>
    </record>

    <record id="action_openrouter_modality" model="ir.actions.act_window">
        <field name="name">OpenRouter Modalities</field>
        <field name="res_model">ai.openrouter.modality</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_openrouter_modality_search"/>
    </record>
</odoo>
