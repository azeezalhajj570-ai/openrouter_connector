<?xml version="1.0"?>
<odoo>

    <record id="res_config_settings_view_form_openrouter" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.openrouter</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="ai_app.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@name='ai_providers']" position="inside">
                <setting id="openrouter_provider" string="Use your own OpenRouter account" help="Connect with 700+ AI models via OpenRouter. Get your free key at openrouter.ai/keys" groups="base.group_system">
                    <field name="openrouter_key_enabled" />
                    <group invisible="not openrouter_key_enabled">
                        <div class="w-100">
                            <field name="openrouter_key" placeholder="OpenRouter API Key" password="True" nolabel="1" class="w-100"/>
                        </div>
                        <button name="action_sync_openrouter_models" string="Sync Models" type="object" icon="fa-refresh" class="btn-link"/>
                    </group>
                </setting>
            </xpath>
        </field>
    </record>

</odoo>
