<odoo>
    <record id="view_openrouter_provider_list" model="ir.ui.view">
        <field name="name">ai.openrouter.provider.list</field>
        <field name="model">ai.openrouter.provider</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="base_url"/>
                <field name="default_route"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_openrouter_provider_form" model="ir.ui.view">
        <field name="name">ai.openrouter.provider.form</field>
        <field name="model">ai.openrouter.provider</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_open_sync_wizard" string="Sync Models" type="object" class="oe_highlight"/>
                </header>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="active"/>
                        <field name="code"/>
                        <field name="api_key" password="True"/>
                        <field name="base_url"/>
                        <field name="default_route"/>
                        <field name="app_url"/>
                        <field name="app_name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_openrouter_provider" model="ir.actions.act_window">
        <field name="name">OpenRouter Configurations</field>
        <field name="res_model">ai.openrouter.provider</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
