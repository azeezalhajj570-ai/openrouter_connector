<odoo>
    <record id="view_openrouter_chat_wizard_form" model="ir.ui.view">
        <field name="name">ai.openrouter.chat.wizard.form</field>
        <field name="model">ai.openrouter.chat.wizard</field>
        <field name="arch" type="xml">
            <form string="Chat with OpenRouter Model">
                <group>
                    <field name="openrouter_model_id"/>
                    <field name="user_prompt" placeholder="Type your prompt..."/>
                    <field name="res_model" invisible="1"/>
                    <field name="res_id" invisible="1"/>
                </group>
                <footer>
                    <button name="action_open_chat" string="Open Chat" type="object" class="oe_highlight"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_openrouter_chat_wizard" model="ir.actions.act_window">
        <field name="name">Chat with OpenRouter Model</field>
        <field name="res_model">ai.openrouter.chat.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <record id="action_openrouter_chat_any_model" model="ir.actions.server">
        <field name="name">Chat with OpenRouter Model</field>
        <field name="model_id" ref="mail.model_mail_thread"/>
        <field name="binding_model_id" ref="mail.model_mail_thread"/>
        <field name="binding_type">action</field>
        <field name="state">code</field>
        <field name="code">action = env.ref('openrouterai_connector.action_openrouter_chat_wizard').read()[0]</field>
    </record>
</odoo>
